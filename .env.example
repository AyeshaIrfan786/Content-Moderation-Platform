# Copy to .env in the project root before running docker-compose
MONGO_URI=mongodb://mongo:27017/content-moderation
PORT=5000
JWT_SECRET=change-me-to-a-long-random-string

# AI moderation provider: gemini 


GEMINI_API_KEY=
 GEMINI_MODEL=gemini-2.5-flash

 Frontend (optional — defaults to /api via nginx proxy)
 VITE_API_URL=/api
